--1580429
pragma table_info(valle);
--Transform lat and lon to numeric variables
ALTER TABLE valle ADD COLUMN lat numeric;
UPDATE valle SET lat = CAST("LATITUDE" as numeric);
ALTER TABLE valle ADD COLUMN lon numeric;
UPDATE valle SET lon = CAST("LONGITUDE" as numeric);
--Create table with only raws and columns of interest
create table cauca1 as select "TAXONOMIC ORDER" as "tax_order", "CATEGORY" as "category", "SCIENTIFIC NAME" as "sci_name", 
"COMMON NAME" as  "comm_name", "EXOTIC CODE" as "exotic", "OBSERVATION COUNT" as "count", "COUNTRY" as "country", "STATE" as "state", "lat", 
"lon", "OBSERVATION DATE" as "dates", "OBSERVER ID" as "observer", "HAS MEDIA" as "media", "GLOBAL UNIQUE IDENTIFIER" as "gui", "TRIP COMMENTS" as "comments" from cauca where 
("CATEGORY" == "species" or "CATEGORY" == "issf" or "CATEGORY" == "form" or "CATEGORY" == "domestic") and ("lat" between 3.8 and 3.9) and ("lon" < -76.78);
pragma table_info(cauca1);


--Import Valle del Cauca provisional data
.import '/Users/diegocueva/Library/CloudStorage/GoogleDrive-dacuevac@unal.edu.co/My Drive/Manacus/ebird-manacus/valle/valle_p.csv' valle_p

UPDATE valle_p SET lat = CAST("LATITUDE" as numeric);
ALTER TABLE valle_p ADD COLUMN lon numeric;
UPDATE valle_p SET lon = CAST("LONGITUDE" as numeric);
create table valle2 as select "TAXONOMIC ORDER" as "tax_order", "CATEGORY" as "category", "SCIENTIFIC NAME" as "sci_name", 
"COMMON NAME" as  "comm_name", "EXOTIC CODE" as "exotic", "OBSERVATION COUNT" as "count", "COUNTRY" as "country", "STATE" as "state", "lat", 
"lon", "OBSERVATION DATE" as "dates", "OBSERVER ID" as "observer", "HAS MEDIA" as "media", "GLOBAL UNIQUE IDENTIFIER" as "gui", "TRIP COMMENTS" as "comments" from valle_p where 
("CATEGORY" == "species" or "CATEGORY" == "issf" or "CATEGORY" == "form" or "CATEGORY" == "domestic") and ("lat" between 3.8 and 3.9) and ("lon" < -76.78);
pragma table_info(valle2);
--Merge tables from valle
create table valle_f as select * from valle1 union select * from valle2;
--Observed birds during the Manacus expedition 2022
create table valle_manacus as select * from valle_f where ("observer" == "obsr164915" or "observer" == "obsr169881" or "observer" == "obsr436508" or "observer" == "obsr792981" 
or "OBSERVER ID" == "obsr803013") and ("dates" between "2022-07-10" and "2022-08-01" );
-- export data to csv
.mode csv
.output valle_pacifico.csv
select * from valle_f;



